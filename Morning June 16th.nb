Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox[
    RowBox[{
     RowBox[{"ephi", "[", "x_", "]"}], " ", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       FractionBox[
        SuperscriptBox[
         RowBox[{"Sin", "[", 
          RowBox[{"\[Lambda]Kphi", "[", "x_", "]"}], "]"}], "2"], 
        SuperscriptBox["\[Lambda]", "2"]]}], ")"}]}], 
    RowBox[{"2", " ", 
     SqrtBox[
      RowBox[{"1", "+", 
       SuperscriptBox["\[Lambda]", "2"]}]], " ", 
     SqrtBox[
      RowBox[{"ex", "[", "x_", "]"}]]}]]}], "-", 
  RowBox[{"Kx", " ", 
   RowBox[{
    SuperscriptBox["ex", "\[Prime]",
     MultilineFunction->None], "[", "x_", "]"}]}], "+", 
  FractionBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"Cos", "[", 
      RowBox[{"\[Lambda]Kphi", "[", "x_", "]"}], "]"}], "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SqrtBox["ex"], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{
           SuperscriptBox["ex", "\[Prime]",
            MultilineFunction->None], "[", "x_", "]"}], 
          RowBox[{"ephi", "[", "x_", "]"}]], ")"}], "\[Prime]",
        MultilineFunction->None]}], "+", 
      FractionBox[
       RowBox[{
        SuperscriptBox[
         SqrtBox[
          RowBox[{"ex", "[", "x_", "]"}]], "\[Prime]",
         MultilineFunction->None], " ", 
        RowBox[{
         SuperscriptBox["ex", "\[Prime]",
          MultilineFunction->None], "[", "x_", "]"}]}], 
       RowBox[{"2", " ", 
        RowBox[{"ephi", "[", "x_", "]"}]}]]}], ")"}]}], 
   RowBox[{"2", " ", 
    SqrtBox[
     RowBox[{"1", "+", 
      SuperscriptBox["\[Lambda]", "2"]}]]}]], "-", 
  FractionBox[
   RowBox[{
    SqrtBox[
     RowBox[{"ex", "[", "x_", "]"}]], " ", 
    RowBox[{"Kx", "[", "x_", "]"}], " ", 
    RowBox[{"Sin", "[", 
     RowBox[{"2", " ", 
      RowBox[{"\[Lambda]Kphi", "[", "x_", "]"}]}], "]"}], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      FractionBox[
       RowBox[{
        SuperscriptBox["\[Lambda]", "2"], " ", 
        SuperscriptBox[
         RowBox[{
          SuperscriptBox["ex", "\[Prime]",
           MultilineFunction->None], "[", "x_", "]"}], "2"]}], 
       RowBox[{"4", " ", 
        SuperscriptBox[
         RowBox[{"ephi", "[", "x_", "]"}], "2"]}]]}], ")"}]}], 
   RowBox[{"\[Lambda]", " ", 
    SqrtBox[
     RowBox[{"1", "+", 
      SuperscriptBox["\[Lambda]", "2"]}]]}]], "+", 
  RowBox[{"ephi", " ", 
